# ============================================================
# 咕咕嘎嘎 AI-VTuber — 环境变量示例
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env
# ============================================================

# ---------- LLM API Key ----------
# MiniMax（默认 LLM 后端）
MINIMAX_API_KEY=

# OpenAI（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Anthropic Claude（可选）
ANTHROPIC_API_KEY=

# ---------- 视觉理解 API Key ----------
# 留空则自动使用 MINIMAX_API_KEY
MINIMAX_VL_API_KEY=

# ---------- 子 Agent（可选）----------
SUBAGENT_API_KEY=

# ---------- HuggingFace 镜像（中国大陆推荐）----------
HF_ENDPOINT=https://hf-mirror.com
