    <script>window.__VP_HASH_MAP__=JSON.parse("{\"guide_vite.md\":\"Dvmc9e6C\",\"about.md\":\"CpUal6Ab\",\"api_interfaces_oml2dproperties.md\":\"DVsWK0LE\",\"api_globals.md\":\"Yjx9tdE0\",\"guide_vitepress.md\":\"CVQK8i-W\",\"changelog.md\":\"BnV2WCnG\",\"api_functions_loadoml2d.md\":\"fWIChPHQ\",\"api_interfaces_oml2dmethods.md\":\"CrOEGZa1\",\"api_interfaces_modeloptions.md\":\"QJ-Oncwn\",\"guide_icon.md\":\"SDwUAACz\",\"api_readme.md\":\"CEjlnGzD\",\"api_interfaces_menusoptions.md\":\"CDZczNtP\",\"guide_index.md\":\"Bk8foDDl\",\"api_interfaces_tipsoptions.md\":\"Co2SPoth\",\"api_interfaces_oml2devents.md\":\"ieh1t_kX\",\"api_interfaces_options.md\":\"Cjne5Txe\",\"guide_vuepress.md\":\"DPeSDATD\",\"guide_models.md\":\"B_wXDHJM\",\"guide_hexo.md\":\"Dex6bK7E\",\"index.md\":\"Co0DlfhS\",\"api_interfaces_statusbaroptions.md\":\"uLnYA-59\"}");window.__VP_SITE_DATA__=JSON.parse("{\"lang\":\"zh-cn\",\"dir\":\"ltr\",\"title\":\"OhMyLive2D\",\"description\":\"支持所有Live2D模型版本的Web组件, 快速为您的个人网站添加看板娘.\",\"base\":\"/\",\"head\":[],\"router\":{\"prefetchLinks\":true},\"appearance\":\"dark\",\"themeConfig\":{\"blog\":{\"pagesData\":[{\"route\":\"/CHANGELOG\",\"meta\":{\"title\":\"Change Log\",\"date\":\"2024-05-08 17:45:54\",\"tag\":[],\"description\":\"All notable changes to this project will be documented in this file.\\nSee Conventional Commits for co\",\"cover\":\"\"}},{\"route\":\"/about\",\"meta\":{\"title\":\"关于\",\"date\":\"2024-03-21 17:47:53\",\"tag\":[],\"description\":\"- `OhMyLive2D` 的模型驱动核心依赖于 pixi-live2d-display, 感谢其为live2d社区作出的贡献\\n- 本站文档构建工具采用 `vitepress`, 主题采用: @su\",\"cover\":\"\"}},{\"route\":\"/api/README\",\"meta\":{\"title\":\"先决条件\",\"date\":\"2024-05-08 13:32:50\",\"tag\":[],\"description\":\"&lt;!-- markdownlint-disable --\\n&lt;p align=\\\"center\\\"&gt;\\n  &lt;img width=\\\"240\\\" style=\\\"text-align:cen\",\"cover\":\"https://img.shields.io/npm/v/oh-my-live2d?label=npm\"}},{\"route\":\"/api/globals\",\"meta\":{\"title\":\"## 接口\",\"date\":\"2024-05-08 07:06:34\",\"tag\":[],\"description\":\"- MenusOptions\\n- ModelOptions\\n- Oml2dEvents\\n- Oml2dMethods\\n- Oml2dProperties\\n- Options\\n- StatusBarOp\",\"cover\":\"\"}},{\"route\":\"/guide/hexo\",\"meta\":{\"title\":\"在 hexo 中使用\",\"date\":\"2024-05-08 14:59:49\",\"tag\":[],\"description\":\"::: tip\\n这是一个第三方插件, 具体使用方式您除了本站之外可能还需要查阅: &lt;https://github.com/kongxiangyiren/hexo-oh-my-live2d\\n:::\",\"cover\":\"\"}},{\"route\":\"/guide/icon\",\"meta\":{\"title\":\"自定义Icon图标\",\"date\":\"2024-03-25 09:41:53\",\"tag\":[],\"description\":\"所有可配置图标的选项您都可以通过以下方式对其自定义\\n 内置的默认图标\\n这些默认图标您可以直接使用: \\n示例:\\n```ts\\nimport { loadOml2d } from 'oh-my-live2d\",\"cover\":\"https://loclink-1259720482.cos.ap-beijing.myqcloud.com/image/202403211826251.png\"}},{\"route\":\"/guide/index\",\"meta\":{\"title\":\"快速入门\",\"date\":\"2024-05-09 12:32:49\",\"tag\":[],\"description\":\"OhMyLive2D 是一个应用于浏览器环境且开箱即用的Live2D组件, 它支持所有版本的Live2D模型, 使用方式足够简单并且高可自定义, 可以快速为您的个人网站添加Live2D看板娘, 使您的\",\"cover\":\"\"}},{\"route\":\"/guide/models\",\"meta\":{\"title\":\"模型资源\",\"date\":\"2024-03-21 15:42:37\",\"tag\":[],\"description\":\"OhMyLive2D 贴心的为您准备了一些高质量模型资源, 并为您附上了对应模型的配置, 以下这些模型静态资源地址大部分来自作者本人的服务器.\\n您可以前往&lt;https://github.com/\",\"cover\":\"https://loclink-1259720482.cos.ap-beijing.myqcloud.com/image/%E5%BD%95%E5%B1%8F2024-03-11%2023.51.51.gif\"}},{\"route\":\"/guide/vite\",\"meta\":{\"title\":\"在 Vite 项目中通过VitePlugin 方式使用\",\"date\":\"2024-03-21 16:47:06\",\"tag\":[],\"description\":\"&gt; 现在您可以通过VitePlugin的方式在Vite构建的项目中使用`oh-my-live2d`, 这看似是一个很`Hack`的方式, 但是需要注意, 该方式目前还是实验性的.\\n 安装插件\\n`\",\"cover\":\"\"}},{\"route\":\"/guide/vitepress\",\"meta\":{\"title\":\"在 VitePress 项目中使用\",\"date\":\"2024-05-08 14:59:49\",\"tag\":[],\"description\":\"由于 VitePress 不提供插件模式, 所以我们可以使用动态导入的形式在主题配置中来使用 `oh-my-live2d`。\\n::: tip\\n😁 由于 vitepress 不支持 plugins, \",\"cover\":\"\"}},{\"route\":\"/guide/vuepress\",\"meta\":{\"title\":\"在 VuePress 中使用\",\"date\":\"2024-05-08 13:32:50\",\"tag\":[],\"description\":\"您可以在 VuePress 项目中通过 `vuepress-plugin-oh-my-live2d` 插件来加载组件。\\n 安装/更新插件\\n```sh\\nnpm install vuepress-plug\",\"cover\":\"\"}},{\"route\":\"/api/functions/loadOml2d\",\"meta\":{\"title\":\"组件加载\",\"date\":\"2024-05-08 14:59:49\",\"tag\":[],\"description\":\"当您需要加载模型时, 您可以在 oh-my-live2d 中导入loadOml2d 方法, 当这个方法被调用时将根据您传入的配置选项来加载组件, 该方法返回一个实例对象, 您可以从 oml2d 这个实\",\"cover\":\"\"}},{\"route\":\"/api/interfaces/MenusOptions\",\"meta\":{\"title\":\"菜单选项\",\"date\":\"2024-05-08 14:59:49\",\"tag\":[],\"description\":\"菜单选项不仅支持传入一个对象, 还支持您传入一个返回选项对象的函数, 如果它是一个函数, 则会在模型每次加载成功时被调用, 调用时会传入当前模型选项以及当前模型的索引值, 这样您就可以根据这些信息来做\",\"cover\":\"\"}},{\"route\":\"/api/interfaces/ModelOptions\",\"meta\":{\"title\":\"模型选项\",\"date\":\"2024-05-08 08:20:46\",\"tag\":[],\"description\":\"模型选项接收一个有模型选项对象组成的数组, 您可以通过这个选项来配置模型地址来源以及缩放比例、舞台大小等\\n 用法:\\n&lt;&lt;&lt; @/usages/options.tsModelOptio\",\"cover\":\"\"}},{\"route\":\"/api/interfaces/Oml2dEvents\",\"meta\":{\"title\":\"实例对象中的事件\",\"date\":\"2024-05-09 03:27:38\",\"tag\":[],\"description\":\"事件可以通过实例对象访问\\n 用法:\\n以下是通过实例对象监听事件的示例:\\n&lt;&lt;&lt; @/usages/oml2d.tsEvents\\n 事件:\\n onLoad()\\n\\n模型加载事件, 加载成\",\"cover\":\"\"}},{\"route\":\"/api/interfaces/Oml2dMethods\",\"meta\":{\"title\":\"实例对象中的方法\",\"date\":\"2024-05-08 14:59:49\",\"tag\":[],\"description\":\"方法可以通过实例对象访问\\n 用法:\\n以下是通过实例对象调用方法的示例:\\n&lt;&lt;&lt; @/usages/oml2d.tsMethods\\n 方法:\\n clearTips()\\n\\n清除当前正在提\",\"cover\":\"\"}},{\"route\":\"/api/interfaces/Oml2dProperties\",\"meta\":{\"title\":\"实例对象中的属性\",\"date\":\"2024-05-08 13:32:50\",\"tag\":[],\"description\":\"属性可以通过实例对象访问\\n 用法:\\n以下是通过实例对象访问属性的示例:\\n&lt;&lt;&lt; @/usages/oml2d.tsProperties\\n 属性:\\n modelIndex\\n\\n当前模型的\",\"cover\":\"\"}},{\"route\":\"/api/interfaces/Options\",\"meta\":{\"title\":\"公共选项\",\"date\":\"2025-01-26 02:38:29\",\"tag\":[],\"description\":\"用法:\\n&lt;&lt;&lt; @/usages/options.tsoptions\\n 选项:\\n dockedPosition?\\n\\n组件停靠位置, 当您希望组件靠右展示时这个属性会非常有用. 同时影\",\"cover\":\"\"}},{\"route\":\"/api/interfaces/StatusBarOptions\",\"meta\":{\"title\":\"状态条选项\",\"date\":\"2024-05-08 07:06:34\",\"tag\":[],\"description\":\"自定义状态条样式以及不同状态的文本和颜色\\n 用法:\\n&lt;&lt;&lt; @/usages/options.tsStatusBarOptions\\n 选项:\\n disable?\\n\\n是否禁用状态条, \",\"cover\":\"\"}},{\"route\":\"/api/interfaces/TipsOptions\",\"meta\":{\"title\":\"提示框选项\",\"date\":\"2024-05-08 13:32:50\",\"tag\":[],\"description\":\"配置提示框样式和消息内容, 与菜单选项一样支持您传入选项对象或者返回选项对象的函数, 如果它是一个函数, 则会在模型每次加载成功时被调用, 调用时会传入当前模型选项以及当前模型的索引值, 这样您就可以\",\"cover\":\"\"}}],\"blog\":false,\"footer\":{\"version\":false,\"copyright\":\"MIT License | Hacxy\"},\"comment\":{\"repo\":\"oh-my-live2d/oh-my-live2d\",\"repoId\":\"R_kgDOIsEpbQ\",\"category\":\"Announcements\",\"categoryId\":\"DIC_kwDOIsEpbc4CTWk1\",\"mapping\":\"title\"},\"themeColor\":\"el-blue\",\"author\":\"Hacxy\",\"popover\":{\"title\":\"公告\",\"body\":[{\"type\":\"text\",\"content\":\"欢迎大家加群&私信交流\"},{\"type\":\"text\",\"content\":\"↓ 微信群 ↓\"},{\"type\":\"image\",\"src\":\"https://hacxy-1259720482.cos.ap-hongkong.myqcloud.com/images/202501261035599.png\",\"style\":\"display: inline-block;width:46%;padding-right:6px\"},{\"type\":\"text\",\"content\":\"由于域名到期, 本站已迁移至: https://oml2d.hacxy.cn\"},{\"type\":\"text\",\"content\":\" 作者微信: coder7915\"}],\"duration\":60000}},\"sidebar\":{\"/api/interfaces\":[{\"text\":\"配置选项\",\"items\":[{\"text\":\"公共选项\",\"link\":\"/api/interfaces/Options\"},{\"text\":\"模型选项\",\"link\":\"/api/interfaces/ModelOptions\"},{\"text\":\"菜单选项\",\"link\":\"/api/interfaces/MenusOptions\"},{\"text\":\"提示框选项\",\"link\":\"/api/interfaces/TipsOptions\"},{\"text\":\"状态栏选项\",\"link\":\"/api/interfaces/StatusBarOptions\"}]},{\"text\":\"实例对象\",\"items\":[{\"text\":\"属性\",\"link\":\"/api/interfaces/Oml2dProperties\"},{\"text\":\"方法\",\"link\":\"/api/interfaces/Oml2dMethods\"},{\"text\":\"事件\",\"link\":\"/api/interfaces/Oml2dEvents\"}]}],\"/\":[{\"text\":\"简介\",\"items\":[{\"text\":\"快速入门\",\"link\":\"/guide/\"},{\"text\":\"组件加载\",\"link\":\"/api/functions/loadOml2d\"},{\"text\":\"自定义图标\",\"link\":\"/guide/icon\"}]},{\"text\":\"使用示例\",\"items\":[{\"text\":\"在vitepress中使用\",\"link\":\"/guide/vitepress\"},{\"text\":\"在vuepress中使用\",\"link\":\"/guide/vuepress\"},{\"text\":\"通过VitePlugin方式使用\",\"link\":\"/guide/vite\"},{\"text\":\"在hexo中使用\",\"link\":\"/guide/hexo\"}]},{\"text\":\"扩展\",\"items\":[{\"text\":\"模型资源\",\"link\":\"/guide/models\"}]}]},\"outline\":{\"level\":[2,4],\"label\":\"目录\"},\"returnToTopLabel\":\"回到顶部\",\"sidebarMenuLabel\":\"相关文章\",\"lastUpdatedText\":\"上次更新于\",\"logo\":{\"dark\":\"/logo-white.png\",\"light\":\"/logo-black.png\"},\"nav\":[{\"text\":\"指南\",\"link\":\"/guide/\"},{\"text\":\"选项\",\"link\":\"/api/interfaces/Options\"},{\"text\":\"使用示例\",\"items\":[{\"text\":\"在vitepress中使用\",\"link\":\"/guide/vitepress\"},{\"text\":\"在vuepress中使用\",\"link\":\"/guide/vuepress\"},{\"text\":\"通过VitePlugin方式使用\",\"link\":\"/guide/vite\"},{\"text\":\"在hexo中使用\",\"link\":\"/guide/hexo\"}]},{\"text\":\"模型资源\",\"link\":\"/guide/models\"},{\"text\":\"关于\",\"link\":\"/about\"},{\"text\":\"v0.19.3\",\"items\":[{\"text\":\"更新日志\",\"link\":\"/CHANGELOG\"}]}],\"socialLinks\":[{\"icon\":\"github\",\"link\":\"https://github.com/oh-my-live2d/oh-my-live2d\"}]},\"locales\":{},\"scrollOffset\":134,\"cleanUrls\":false}");</script>
    
